$action = New-ScheduledTaskAction -Execute "PowerShell.exe" -Argument "-NoProfile -ExecutionPolicy Bypass -Command `"Remove-Item -Path '$env:TEMP\*' -Recurse -Force; Clear-RecycleBin -Force -Confirm:`$false`""
$trigger = New-ScheduledTaskTrigger -Daily -At "3AM"
Register-ScheduledTask -TaskName "ZORGAutoSpaceRape" -Action $action -Trigger $trigger -User "System" -RunLevel Highest -Force