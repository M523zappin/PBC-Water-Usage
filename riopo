# Find largest folders (top 20)
Get-ChildItem C:\ -Recurse -ErrorAction SilentlyContinue | 
  Where-Object { $_.PSIsContainer } | 
  ForEach-Object { 
    $size = (Get-ChildItem $_.FullName -Recurse -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum).Sum 
    [PSCustomObject]@{ Folder = $_.FullName; SizeGB = [math]::Round($size / 1GB, 2) } 
  } | Sort-Object SizeGB -Descending | Select-Object -First 20 | Format-Table -AutoSize

# Also top large files
Get-ChildItem C:\ -Recurse -File -ErrorAction SilentlyContinue | 
  Sort-Object Length -Descending | 
  Select-Object FullName, @{Name="SizeGB"; Expression={[math]::Round($_.Length / 1GB, 2)}} -First 15 | Format-Table -AutoSize