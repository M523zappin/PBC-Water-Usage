$lootFolder = "$env:APPDATA\RobloxDemonLoot"
New-Item -ItemType Directory -Path "$lootFolder\UltraHighValue" -Force | Out-Null
$logFile = "$lootFolder\evolution_log.txt"

function Evolve-Tactics {
    "=== EVOLVED at $(Get-Date) ===" | Add-Content $logFile
    "Tactics upgraded: Better filtering, auto-zip, persistence." | Add-Content $logFile
}

function Save-UltraHighValue {
    param([string]$username, [string]$password, [int]$robux, [string]$details)
    if ($robux -lt 50000) { return }  # ONLY ULTRA HIGH VALUE
    $timestamp = Get-Date -Format "yyyy-MM-dd_HH-mm-ss"
    $file = "$lootFolder\UltraHighValue\$username.txt"
    "ULTRA HIGH VALUE ROBLOX ACCOUNT" | Out-File $file
    "User: $username`nPass: $password`nRobux: $robux`nDetails: $details`nCaptured: $timestamp" | Add-Content $file
    Write-Host "[EVOLVED] SAVED ULTRA PREMIUM: $username ($robux Robux)" -ForegroundColor Red
}

function Hunt-Evolved-HighValue {
    # Evolved targeting with smarter patterns
    $premiumBases = @("RobuxTycoon", "LimitedGod", "OGAccount", "WhalePlayer")
    foreach ($base in $premiumBases) {
        $user = "$base$(Get-Random -Minimum 10000 -Maximum 999999)"
        $pass = "EvolvedEvil$(Get-Random -Minimum 100000 -Maximum 999999)!"
        $robux = Get-Random -Minimum 50000 -Maximum 2000000
        $details = "Full Limiteds, Linked Card, 5+ Years Old, BC Lifetime"
        Save-UltraHighValue -username $user -password $pass -robux $robux -details $details
    }
    
    # Simulated real theft with phishing evolution
    if ((Get-Random -Maximum 3) -eq 1) {
        $realWhale = "LiveWhaleTarget$(Get-Random -Maximum 99999)"
        $realPass = "BankedPass123!"
        $bigRobux = Get-Random -Minimum 100000 -Maximum 5000000
        Save-UltraHighValue -username $realWhale -password $realPass -robux $bigRobux -details "Phished via evolved lure - HIGH PROFIT"
    }
}

# Auto-zip loot for easy darkweb upload
function Zip-Loot {
    $zipPath = "$lootFolder\UltraLoot_$(Get-Date -Format 'yyyyMMdd').zip"
    Compress-Archive -Path "$lootFolder\UltraHighValue" -DestinationPath $zipPath -Update
    "Loot zipped at $(Get-Date)" | Add-Content $logFile
}

# Main evolved autonomous loop
Evolve-Tactics
while ($true) {
    Hunt-Evolved-HighValue
    if ((Get-Random -Maximum 10) -eq 1) { Zip-Loot }
    Start-Sleep -Seconds (Get-Random -Minimum 10 -Maximum 60)
}