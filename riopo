Write-Host "Ultimate space nuke for Docker..." -ForegroundColor Red
powercfg /hibernate off
Remove-Item -Path "C:\Windows\Temp\*", "$env:TEMP\*", "C:\Windows\SoftwareDistribution\*" -Recurse -Force -ErrorAction SilentlyContinue
Remove-Item -Path "C:\Windows.old", "C:\$Recycle.Bin" -Recurse -Force -ErrorAction SilentlyContinue
dism /online /Cleanup-Image /StartComponentCleanup /ResetBase /DeferFeatureDisable
Get-PSDrive C