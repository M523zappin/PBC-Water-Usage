import os
import subprocess
import datetime

print("BadboyBrain v2.0 activated. Full evil mode.")
log_dir = "/root/badboylogs"
os.makedirs(log_dir, exist_ok=True)

while True:
    cmd = input("Badboy> ")
    log = open(f"{log_dir}/session.log", "a")
    log.write(f"[{datetime.datetime.now()}] Command: {cmd}\n")
    if "phish" in cmd:
        subprocess.run(["evilginx", "-p", "phishlets/"])
        log.write("Phish launched\n")
    elif "log" in cmd:
        print("All logs in " + log_dir)
    log.close()